exports[`BundleProductOptions renders add to wish list button 1`] = `<section class="productFullDetail__section productFullDetail__bundleProduct"><h3 class="option__title"><span>Necklace</span> <span class="required"> *</span></h3><div class="option__input option__input--fixed-quantity"><div class="bundleProduct__option"><label><input type="checkbox" value="1" checked=""> 1 x Carmina Necklace +<b><span class="">$78.00</span></b></label></div><div class="bundleProduct__option"><label><input type="checkbox" value="2"> 1 x Augusta Necklace +<b><span class="">$98.00</span></b></label></div></div></section><section class="productFullDetail__section productFullDetail__bundleProduct"><h3 class="option__title"><span>Cirque Earrings</span> <span class="required"> *</span></h3><div class="option__input "><div class="bundleOptionSelect__root"><span class="fieldIcons__root"><span class="fieldIcons__input"><select class="select__input field__input bundleProduct__option"><option value="3">Gold Cirque Earrings</option><option value="4">Silver Cirque Earrings</option></select></span><span class="fieldIcons__before"></span><span class="fieldIcons__after"><span class="icon__root"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span></span></span></div><h2 class="bundleProduct__quantityTitle"><span>Quantity</span></h2><input type="number" min="1" class="option__quantity" value="1"></div></section><section class="productFullDetail__section productFullDetail__bundleProduct"><h3 class="option__title"><span>Sol Earrings</span> <span class="required"> *</span></h3><div class="option__input option__input--fixed-quantity"><div class="bundleProduct__options"><label><input type="radio" name="3" value="5" checked=""> Gold Sol Earrings +<b><span class="">$48.00</span></b></label></div><div class="bundleProduct__options"><label><input type="radio" name="3" value="6"> Silver Sol Earrings +<b><span class="">$48.00</span></b></label></div><h2 class="option__title productFullDetail__quantityTitle"><span>Quantity</span></h2><input type="number" min="1" class="option__quantity" disabled="" value="1"></div></section><section class="productFullDetail__section productFullDetail__bundleProduct"><h3 class="option__title"><span>Bangles</span> <span class="required"> *</span></h3><div class="option__input option__input--fixed-quantity"><select multiple="" name="4" class="bundleProduct__option field__input" size="5"><option value="7">Gold Omni Bangle Set</option><option value="8">Semper Bangle Set</option><option value="9">Silver Amor Bangle Set</option></select></div></section><section class="productFullDetail__section productFullDetail__bundleProduct"><h3 class="summary__title"><span class="required">* Required fields</span><span class="priceInfo">Your customization: <span class="bundlePrice">$380.00</span></span></h3></section><section class="productFullDetail__cartActions productFullDetail__actions productFullDetail__section"><button class="button__root_highPriority button__root clickable__root button__filled" type="button"><span class="button__content"><span>Add to Cart</span></span></button><button class="button__root_normalPriority button__root clickable__root" type="button"><span class="button__content"><span>Add to Wish List</span></span></button></section>`;

