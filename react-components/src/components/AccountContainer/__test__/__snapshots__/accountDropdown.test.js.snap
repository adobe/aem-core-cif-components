exports[`<AccountDropdown> renders the account created component inside account dropdown 1`] = `<button data-role="mask"></button><div class="root" aria-label="account dropdown"><div class="root"><div class="body"><h2 class="header">Your account was successfully created</h2><div class="textBlock">You will receive a link at . Access that link to confirm your email address.</div><div class="actions"><button class="root" type="button"><span class="signin">Sign In</span></button></div></div></div></div>`;

exports[`<AccountDropdown> renders the change password component inside account dropdown 1`] = `<button data-role="mask"></button><div class="root" aria-label="account dropdown"><div class="root"><form><div class="root"><label><span class="label"><span class="requiredSymbol"></span>Current Password</span></label><span class="root" style="--iconsBefore: 0; --iconsAfter: 0;"><span class="input"><input type="password" aria-label="old-password" class="input" name="oldPassword" value=""></span><span class="before"></span><span class="after"></span></span><p class="root"></p></div><div class="root"><label><span class="label"><span class="requiredSymbol"></span>New Password</span></label><span class="root" style="--iconsBefore: 0; --iconsAfter: 0;"><span class="input"><input type="password" autocomplete="password" aria-label="password" class="input" name="password" value=""></span><span class="before"></span><span class="after"></span></span><p class="root"></p></div><div class="root"><label><span class="label"><span class="requiredSymbol"></span>Confirm New Password</span></label><span class="root" style="--iconsBefore: 0; --iconsAfter: 0;"><span class="input"><input type="password" aria-label="confirm" class="input" name="confirm" value=""></span><span class="before"></span><span class="after"></span></span><p class="root"></p></div><div class="actions"><button class="root_highPriority" type="submit" aria-label="submit"><span class="content">Change Password</span></button><button class="root_normalPriority" type="button" aria-label="cancel"><span class="content">Cancel</span></button></div></form></div></div>`;

exports[`<AccountDropdown> renders the create account component inside account dropdown 1`] = `<button data-role="mask"></button><div class="root" aria-label="account dropdown"><form><p>Check out faster, use multiple addresses, track orders and more by creating an account!</p><div class="root"><label><span class="label"><span class="requiredSymbol"></span>First Name</span></label><span class="root" style="--iconsBefore: 0; --iconsAfter: 0;"><span class="input"><input autocomplete="given-name" aria-label="firstname" class="input" name="customer.firstname" value=""></span><span class="before"></span><span class="after"></span></span><p class="root"></p></div><div class="root"><label><span class="label"><span class="requiredSymbol"></span>Last Name</span></label><span class="root" style="--iconsBefore: 0; --iconsAfter: 0;"><span class="input"><input autocomplete="family-name" aria-label="lastname" class="input" name="customer.lastname" value=""></span><span class="before"></span><span class="after"></span></span><p class="root"></p></div><div class="root"><label><span class="label"><span class="requiredSymbol"></span>Email address</span></label><span class="root" style="--iconsBefore: 0; --iconsAfter: 0;"><span class="input"><input autocomplete="email" aria-label="email" class="input" name="customer.email" value=""></span><span class="before"></span><span class="after"></span></span><p class="root"></p></div><div class="root"><label><span class="label"><span class="requiredSymbol"></span>Password</span></label><span class="root" style="--iconsBefore: 0; --iconsAfter: 0;"><span class="input"><input type="password" autocomplete="new-password" aria-label="password" class="input" name="password" value=""></span><span class="before"></span><span class="after"></span></span><p class="root"></p></div><div class="root"><label><span class="label"><span class="requiredSymbol"></span>Confirm Password</span></label><span class="root" style="--iconsBefore: 0; --iconsAfter: 0;"><span class="input"><input type="password" aria-label="confirm" class="input" name="confirm" value=""></span><span class="before"></span><span class="after"></span></span><p class="root"></p></div><div><label class="root"><span class="icon"></span><input type="checkbox" aria-label="subscribe" class="input" name="subscribe"><span class="label">Subscribe to news and updates</span></label><p class="root"></p></div><div></div><div><button class="root_highPriority" type="submit" aria-label="submit"><span class="content">Submit</span></button><button class="root_normalPriority" type="button" aria-label="cancel"><span class="content">Cancel</span></button></div></form></div>`;

exports[`<AccountDropdown> renders the forgot password component inside account dropdown 1`] = `<button data-role="mask"></button><div class="root" aria-label="account dropdown"><div class="root"><p class="instructions">Enter your email below to receive a password reset link.</p><form><div class="root"><label><span class="label"><span class="requiredSymbol"></span>Email address</span></label><span class="root" style="--iconsBefore: 0; --iconsAfter: 0;"><span class="input"><input autocomplete="email" aria-label="email" class="input" name="email" value=""></span><span class="before"></span><span class="after"></span></span><p class="root"></p></div><div><button class="root_highPriority" type="submit" aria-label="submit"><span class="content">Submit</span></button><button class="root_normalPriority" type="button" aria-label="cancel"><span class="content">Cancel</span></button></div></form></div></div>`;

exports[`<AccountDropdown> renders the my account component inside account dropdown 1`] = `<button data-role="mask"></button><div class="root" aria-label="account dropdown"><div class="root"><div class="user"><h2 class="title"> </h2><span class="subtitle"></span></div><div class="actions"><button type="button" classes="[object Object]"><span><span><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg></span><span>Change Password</span></span></button><button type="button" classes="[object Object]"><span><span><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg></span><span>Address Book</span></span></button><button type="button" classes="[object Object]"><span><span><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg></span><span>Account Information</span></span></button><button type="button" classes="[object Object]"><span><span><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg></span><span>Sign Out</span></span></button></div></div></div>`;
