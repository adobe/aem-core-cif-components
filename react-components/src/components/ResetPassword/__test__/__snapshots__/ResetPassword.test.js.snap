// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`ResetPassword renders a success message 1`] = `<div class="root"><p class="lead">Your password was changed. Please log in with your new password.</p></div>`;

exports[`ResetPassword renders an error message for a failed password reset 1`] = `<div class="error">Could not reset password.</div>`;

exports[`ResetPassword renders an error message for a missing token 1`] = `<div class="error">Missing or invalid token.</div>`;

exports[`ResetPassword renders the form 1`] = `<form class="root"><p class="lead">Please choose a new password to complete the password reset.</p><div class="fields"><div class="root"><label><span class="label"><span class="requiredSymbol"></span>Email address</span></label><span class="root" style="--iconsBefore: 0; --iconsAfter: 0;"><span class="input"><input autocomplete="email" aria-label="email" class="input" name="email" value=""></span><span class="before"></span><span class="after"></span></span><p class="root"></p></div><div class="root"><label><span class="label"><span class="requiredSymbol"></span>New Password</span></label><span class="root" style="--iconsBefore: 0; --iconsAfter: 0;"><span class="input"><input type="password" autocomplete="new-password" aria-label="password" class="input" name="password" value=""></span><span class="before"></span><span class="after"></span></span><p class="root"></p></div><div class="root"><label><span class="label"><span class="requiredSymbol"></span>Confirm new Password</span></label><span class="root" style="--iconsBefore: 0; --iconsAfter: 0;"><span class="input"><input type="password" aria-label="confirm" class="input" name="confirm" value=""></span><span class="before"></span><span class="after"></span></span><p class="root"></p></div></div><div class="submit"><button class="root_highPriority" type="submit" aria-label="submit"><span class="content">Reset Password</span></button></div></form>`;
